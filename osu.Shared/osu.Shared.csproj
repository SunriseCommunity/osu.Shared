<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard1.0;net20</TargetFrameworks>
    <Version>1.0.4</Version>
    <Authors>richardscull / HoLLy</Authors>
    <Product>osu.Shared</Product>
    <PackageId>richardscull.osu.Shared</PackageId>
    <Description>Shared code to be used by osu!-related programs.</Description>
    <Copyright>Copyright 2026</Copyright>
    <PackageLicenseUrl>https://github.com/SunriseCommunity/osu.Shared/blob/master/LICENSE</PackageLicenseUrl>
    <PackageProjectUrl>https://github.com/SunriseCommunity/osu.Shared/</PackageProjectUrl>
    <RepositoryUrl>https://github.com/SunriseCommunity/osu.Shared/</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>osu! osu</PackageTags>
    <PackageReleaseNotes>Add Mirror mod</PackageReleaseNotes>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCPU'">
    <LangVersion>7.1</LangVersion>
  </PropertyGroup>

  <PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCPU'">
    <LangVersion>7.1</LangVersion>
  </PropertyGroup>

</Project>
